# penguin

## homebrew
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

## combo 'up' alias
alias up='sudo apt update && sudo apt upgrade -y && brew update && brew upgrade && brew cleanup'

## load NVM
source "$HOME/.files-common/shard/nvm"

## load NPM aliases
source "$HOME/.files-common/shard/npm"