# MACX

## aliases
alias spid='"$HOME/OneDrive - J.B. Hunt Transport/Custom/Mac/secure-pid-maker.sh"'
alias trivyscan='echo "Scanning ${PWD##*/}..." && trivy fs --security-checks vuln,config . > "$HOME/OneDrive - J.B. Hunt Transport/TrivyScan/${PWD##*/}.txt" && echo "Saved to OneDrive/TrivyScan/${PWD##*/}.txt"'

## google cloud autocomplete
source "$(brew --prefix)/Caskroom/google-cloud-sdk/latest/google-cloud-sdk/path.zsh.inc"
source "$(brew --prefix)/Caskroom/google-cloud-sdk/latest/google-cloud-sdk/completion.zsh.inc"

## load NPM aliases
source "$HOME/.files-common/shard/npm"